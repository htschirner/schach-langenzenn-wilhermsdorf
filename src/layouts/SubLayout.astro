---
import '../styles/global.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/600.css';
import '@fontsource/source-sans-3/300.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/600.css';
import ChessLogo from '../components/ChessLogo.astro';

interface Props {
  title: string;
  logoName: string;
  logoSub?: string;
  footerText: string;
  noindex?: boolean;
}

const { title, logoName, logoSub, footerText, noindex = true } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {noindex && <meta name="robots" content="noindex, nofollow">}
  <title>{title}</title>
</head>
<body>

<header>
  <div class="header-inner" style="max-width:800px">
    <a href={base || '/'} class="site-title">
      <div class="logo-icon" aria-hidden="true">
        <ChessLogo />
      </div>
      <div class="site-title-text">
        <span class="name">{logoName}</span>
        {logoSub && <span class="sub">{logoSub}</span>}
      </div>
    </a>
    <a href={base || '/'} class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
      Zur Hauptseite
    </a>
  </div>
</header>

<slot />

<footer>
  <p>{footerText}</p>
  <p style="margin-top:0.3rem;">
    <a href={base || '/'}>&#8592; Zurück zur Hauptseite</a>
    &nbsp;&middot;&nbsp;
    <a href={`${base}/impressum-datenschutz.html`}>Impressum</a>
    &nbsp;&middot;&nbsp;
    <a href={`${base}/impressum-datenschutz.html#datenschutz`}>Datenschutz</a>
  </p>
</footer>

</body>
</html>
