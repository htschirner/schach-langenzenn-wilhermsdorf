---
import '../styles/global.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/600.css';
import '@fontsource/eb-garamond/400.css';
import '@fontsource/source-sans-3/300.css';
import '@fontsource/source-sans-3/400.css';
import '@fontsource/source-sans-3/600.css';
import ChessLogo from '../components/ChessLogo.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="google-site-verification" content="TGclI-X1tp-Tw3VFQ9NizwqGJIECKFBXP1R7biwid2I" />
  <meta name="description" content="Schachverein für Langenzenn, Wilhermsdorf, Markt Erlbach und Neuhof an der Zenn. SK 1948 Langenzenn und Schachfreunde Wilhermsdorf – wöchentlicher Spielabend freitags, Mannschaftswettkämpfe im Kreis Mittelfranken Nord." />
  <title>{title}</title>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SportsClub",
    "name": "SG Langenzenn/Wilhermsdorf",
    "alternateName": ["SK 1948 Langenzenn", "Schachfreunde Wilhermsdorf"],
    "url": "https://www.schach-langenzenn-wilhermsdorf.de",
    "sport": "Schach",
    "description": "Schachverein für Langenzenn, Wilhermsdorf, Markt Erlbach und Neuhof an der Zenn",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Langenzenn",
      "addressRegion": "Bayern",
      "addressCountry": "DE"
    }
  }
  </script>
</head>
<body>

<header>
  <div class="header-inner" style="max-width:1000px">
    <a href={base || '/'} class="site-title">
      <div class="logo-icon" aria-hidden="true">
        <ChessLogo />
      </div>
      <div class="site-title-text">
        <span class="name">SG Langenzenn / Wilhermsdorf</span>
        <span class="sub">SK 1948 Langenzenn &#9822; Schachfreunde Wilhermsdorf</span>
      </div>
    </a>
    <button class="burger" id="burger-btn" aria-label="Menü öffnen" aria-expanded="false" aria-controls="main-nav">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <nav aria-label="Hauptnavigation" id="main-nav">
      <a href="#willkommen">Willkommen</a>
      <a href="#ueber-uns">Über uns</a>
      <a href="#spielabend">Spielabend</a>
      <a href="#mannschaft">Mannschaft</a>
      <a href="#termine">Termine</a>
      <a href={`${base}/berichte.html`}>Berichte</a>
    </nav>
  </div>
</header>

<slot />

<footer>
  <p>SG Langenzenn/Wilhermsdorf &nbsp;&middot;&nbsp; SK 1948 Langenzenn &#9822; Schachfreunde Wilhermsdorf</p>
  <p style="margin-top:0.3rem;">
    <a href={`${base}/impressum-datenschutz.html`}>Impressum</a> &nbsp;&middot;&nbsp;
    <a href={`${base}/impressum-datenschutz.html#datenschutz`}>Datenschutz</a>
  </p>
</footer>

<script>
  const btn = document.getElementById('burger-btn');
  const nav = document.getElementById('main-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
    });
    nav.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        nav.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Menü öffnen');
      });
    });
  }
</script>
</body>
</html>
