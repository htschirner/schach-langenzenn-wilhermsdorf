---
import SubLayout from '../layouts/SubLayout.astro';
---
<SubLayout
  title="SK 1948 Langenzenn"
  logoName="SK 1948 Langenzenn"
  logoSub="Teil der SG Langenzenn / Wilhermsdorf"
  footerText="SK 1948 Langenzenn · Teil der SG Langenzenn / Wilhermsdorf"
>

<div class="page-wrap">

  <div class="section" id="verein">
    <h2 class="section-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      SK 1948 Langenzenn
    </h2>
    <p>
      1948 gegründet, von 1948 bis 1989 Schachabteilung des TSV Langenzenn,
      seit 1989 eigenständiger Verein. Seitdem verwendet der Verein das Stadtwappen von Langenzenn als Vereinslogo.
    </p>

    <div class="wappen-row">
      <table class="info-table">
      <tr>
        <td>Gegründet</td>
        <td>
          <b>09.02.1948</b>, danach für über 40 Jahre Abteilung des TSV Langenzenn,
          <b>09.06.1989</b> Gründung des SK 1948 Langenzenn
        </td>
      </tr>
      <tr>
        <td>Sitz</td>
        <td>
          <strong>Langenzenn</strong>
          <span>Landkreis Fürth, Bayern</span>
        </td>
      </tr>
      <tr>
        <td>Kontakt</td>
        <td>
          <strong>Michael Jagla</strong>
          <span><a id="mail-link-langenzenn" href="#"></a></span>
        </td>
      </tr>
    </table>
      <img
        class="verein-wappen"
        src="/schach-langenzenn-wilhermsdorf/wappen-langenzenn.svg"
        alt="Stadtwappen Langenzenn"
        width="90"
        height="120"
      />
    </div>
  </div>

  <div class="section" id="geschichte">
    <h2 class="section-title">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
      Vereinsgeschichte
    </h2>
    <p>Zum 50-jährigen Jubiläum des Schachklubs im Jahr 1998:</p>
    <blockquote class="article-quote">
      Am 9. Februar 1948 rief eine Anzahl froher junger Männer - darunter unsere Gründungsmitglieder Gustav Klima und Johann Steinmetz, 
      die von der Schönheit und Vielfalt des "Königlichen Spiels" begeistert waren, einen Schachklub ins Leben. 
      Gar bald schloß man sich aus organisatorischen Gründen dem TSV Langenzenn als Abteilung an. 
      Die Schachsparte umfaßte damals 20 Aufnahmemitglieder und Mitbegründer. Zum damaligen Spartenleiter und Vorstand wurde 
      Friedrich Weiß gewählt. Der erste Mannschaftskampf wurde am 06.04.1948 gegen Wilhermsdorf mit 16:12 Punkten verloren. 
      Im Rückkampf am 10.04.1948 wurde in Wilhermsdorf bei Kiesel mit 21½:13½ gewonnen! 
      So wurde es in der Stammrolle vermerkt. Der erste Vereinsmeister wurde Karl Feigel. 
    </blockquote>

    <div class="image-gallery">
      <button onclick="document.getElementById('lightbox').showModal(); document.getElementById('lightbox-img').src=this.querySelector('img').src">
        <img
          src="/schach-langenzenn-wilhermsdorf/langenzenn-stammrolle-1.webp"
          alt="Stammrolle SK 1948 Langenzenn (Seite 1)"
        />
      </button>
      <button onclick="document.getElementById('lightbox').showModal(); document.getElementById('lightbox-img').src=this.querySelector('img').src">
        <img
          src="/schach-langenzenn-wilhermsdorf/langenzenn-stammrolle-2.webp"
          alt="Stammrolle SK 1948 Langenzenn (Seite 2)"
        />
      </button>
    </div>

    <dialog id="lightbox" class="lightbox" onclick="this.close()">
      <img id="lightbox-img" src="" alt="Vergrößerte Ansicht" />
    </dialog>
  </div>

</div>

<script is:inline>
(function(){
  var u = 'sk1948langenzenn', d = 'freenet.de';
  var a = document.getElementById('mail-link-langenzenn');
  if (a) { a.href = 'mailto:' + u + '@' + d; a.textContent = u + '@' + d; }
})();
</script>

</SubLayout>
