<style>
  .meister-table {
    border-collapse: collapse;
    width: 100%;
    max-width: 420px;
    font-size: 0.95rem;
  }
  .meister-table th {
    text-align: left;
    padding: 0.4rem 1rem 0.4rem 0;
    border-bottom: 2px solid var(--accent);
    color: var(--accent);
    font-family: 'Lora', serif;
    font-weight: 600;
  }
  .meister-table td {
    padding: 0.3rem 1rem 0.3rem 0;
    border-bottom: 1px solid #e0d8cc;
    vertical-align: top;
  }
  .meister-table td:first-child {
    font-weight: 600;
    white-space: nowrap;
    color: var(--accent);
    width: 4rem;
  }
  .meister-table tbody tr:last-child td {
    border-bottom: none;
  }
</style>

<script is:inline>
(function(){
  var u = 'sk1948langenzenn', d = 'freenet.de';
  var a = document.getElementById('mail-link-langenzenn');
  if (a) { a.href = 'mailto:' + u + '@' + d; a.textContent = u + '@' + d; }
})();
</script>

</SubLayout>
