---
import MainLayout from '../layouts/MainLayout.astro';
import { getTermine } from '../lib/termine';

const termine = getTermine();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<MainLayout title="SG Langenzenn/Wilhermsdorf">

<div class="page-grid">
  <main>

    <!-- WILLKOMMEN -->
    <section class="section" id="willkommen">
      <h2 class="section-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Schach in Langenzenn, Wilhermsdorf und Umgebung
      </h2>
      <p>
        Die SG Langenzenn/Wilhermsdorf ist eine Spielgemeinschaft des SK 1948 Langenzenn und
        der Schachfreunde Wilhermsdorf. Gemeinsam treffen wir uns freitags zu unserem Spielabend
        und bestreiten (in der Regel ebenfalls freitags) die Mannschaftswettkämpfe im Kreis Mittelfranken Nord.
      </p>
      <p>
        Wir freuen uns über alle, die Interesse am Schach haben und einfach mal am Spielabend vorbeischauen. 
        Bei uns sind alle willkommen: Egal ob jung oder schon älter, ob Neuling oder mit Turniererfahrung – 
        auch wer nach langer Pause wieder einsteigen möchte: Einfach vorbeikommen!
      </p>
      <div class="info-box">
        <span aria-hidden="true" style="font-size:1.6rem;line-height:1;color:#2a5c8a;flex-shrink:0;letter-spacing:0.05em;">&#9812;&#9813;&#9820;</span>
        <p>Spielabend: <strong>Freitags ab 19:30 Uhr</strong> in Wilhermsdorf (Bergstr. 13)</p>
      </div>
    </section>

    <!-- ÜBER UNS -->
    <section class="section" id="ueber-uns">
      <h2 class="section-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Über uns
      </h2>
      <p>
        Die SG Langenzenn/Wilhermsdorf besteht aus zwei eigenständigen Vereinen, die ihre Kräfte
        für den Spielbetrieb und den gemeinsamen Spielabend bündeln.
      </p>

      <div class="verein-cols">
        <a href={`${base}/verein-langenzenn.html`} class="verein-box">
          <h3>SK 1948 Langenzenn <span class="link-arrow">&#8599;</span></h3>
          <p>Gegründet 1948. Der Schachklub ist seit Jahrzehnten ein fester Teil des Vereinslebens in der Stadt Langenzenn.</p>
        </a>
        <a href={`${base}/verein-wilhermsdorf.html`} class="verein-box">
          <h3>Schachfreunde Wilhermsdorf <span class="link-arrow">&#8599;</span></h3>
          <p>Die Schachfreunde Wilhermsdorf stehen für das Schachspiel im Markt Wilhermsdorf und der Umgebung.</p>
        </a>
      </div>

      <p style="margin-top:1rem;">
        Mitglied werden kann man in einem der beiden Vereine.
        Wer Interesse hat, kann sich beim Spielabend oder per Kontakt melden &ndash; wir erklären alles Weitere gerne persönlich.
      </p>
    </section>

    <!-- SPIELABEND -->
    <section class="section" id="spielabend">
      <h2 class="section-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Spielabend
      </h2>
      <table class="info-table">
        <tr>
          <td>Wann</td>
          <td>
            <strong>Jeden Freitag ab 19:30 Uhr</strong>
            <span>Das ganze Jahr über, auch außerhalb der Ligasaison (Ausnahmen: 
              Feiertage und Spieltage der Mannschaftswettbewerbe)</span>
          </td>
        </tr>
        <tr>
          <td>Wo</td>
          <td>
            <strong>Evangelische Gemeinschaft</strong>
            <span>Bergstraße 13, 91452 Wilhermsdorf</span>
            <span>
              <a href="https://www.google.com/maps/search/?api=1&query=Bergstra%C3%9Fe+13%2C+91452+Wilhermsdorf" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:0.3rem;margin-top:0.4rem;font-size:0.82rem;color:var(--accent);text-decoration:none;font-weight:600;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                Anfahrt (Google Maps)
              </a>
            </span>
          </td>
        </tr>
        <tr>
          <td>Für wen</td>
          <td>
            <strong>Alle Altersgruppen, alle Spielstärken</strong>
            <span>Vorkenntnisse sind willkommen, aber keine Voraussetzung</span>
          </td>
        </tr>
      </table>
    </section>

    <!-- MANNSCHAFT -->
    <section class="section" id="mannschaft">
      <h2 class="section-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Mannschaftswettbewerbe
      </h2>
      <p>
        Die SG Langenzenn/Wilhermsdorf nimmt am Spielbetrieb des Schachkreises Mittelfranken Nord teil.
        Die Ligakämpfe finden in der Regel an Freitagabenden statt und werden gemeinsam
        von beiden Vereinen als Spielgemeinschaft bestritten.
      </p>
      <p>
        In der Kreisliga 1 haben wir in der Saison 2025/26 den 9.&nbsp;Platz belegt und spielen deshalb
        voraussichtlich in der kommenden Saison in der Kreisliga 2. Da kann das Ziel nur der sofortige Wiederaufstieg sein!
      </p>
      <p><strong>Aufstellung Saison 2025/26:</strong></p>
      <ol class="aufstellung-list">
        <li>Herbert Jäger</li>
        <li>Dieter Eberle</li>
        <li>Michael Jagla</li>
        <li>Alexander Franz</li>
        <li>Rudolf Derbsch</li>
        <li>Werner Käferlein</li>
        <li>Gerhard Tobisch</li>
        <li>Norbert Franz</li>
        <li>Michael Anskat</li>
        <li>Henning Tschirner</li>
      </ol>

      <p><strong>Ergebnisse Saison 2025/26:</strong></p>
      <table class="ergebnisse-table">
        <thead>
          <tr>
            <th>Spieltag</th>
            <th>Datum</th>
            <th>Begegnung</th>
            <th>Ergebnis</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>1</td><td>10.10.2025</td><td>SG Langenzenn/Wilhermsdorf – SF Fürth 2</td><td>2½ - 5½</td></tr>
          <tr><td>2</td><td>26.10.2025</td><td>SV Bubenreuth 1 – SG Langenzenn/Wilhermsdorf</td><td>6½ - 1½</td></tr>
          <tr><td>3</td><td>14.11.2025</td><td>SG Langenzenn/Wilhermsdorf – SC Forchheim 2</td><td>½ - 7½</td></tr>
          <tr><td>4</td><td>05.12.2025</td><td>SG Kirchehrenbach/E'stadt 1 – SG Langenzenn/Wilhermsdorf</td><td>4 - 4</td></tr>
          <tr><td>5</td><td>16.01.2026</td><td>SG Langenzenn/Wilhermsdorf – SG Fürth 3</td><td>5½ - 2½</td></tr>
          <tr><td>6</td><td>06.02.2026</td><td>SG Langenzenn/Wilhermsdorf – SC Pottenstein 1</td><td>4 - 4</td></tr>
          <tr><td>7</td><td>27.02.2026</td><td>SC Erlangen 4 – SG Langenzenn/Wilhermsdorf</td><td>3½ - 4½</td></tr>
          <tr><td>8</td><td>20.03.2026</td><td>SG Langenzenn/Wilhermsdorf – SG Eckental 1</td><td>3½ - 4½</td></tr>
          <tr><td>9</td><td>22.04.2026</td><td>SC Eggerbachtal 1 – SG Langenzenn/Wilhermsdorf</td><td>5 - 3</td></tr>
        </tbody>
      </table>

      <p>
        Alle Tabellen und Ergebnisse sind über den
        <a href="https://www.ligamanager.schachbund-bayern.de/mfr-nord/ergebnisse/spielplan.htm?ligaId=2531" target="_blank" rel="noopener">Schachbund Bayern</a> abrufbar.
      </p>
    </section>

    <!-- TERMINE -->
    <section class="section" id="termine">
      <h2 class="section-title">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Termine
      </h2>
      <p>Die nächsten Termine der SG Langenzenn/Wilhermsdorf und anstehende Turniere in der fränkischen Umgebung:</p>

      {termine.length === 0 ? (
        <ul class="termine-list">
          <li style="color:var(--muted);font-size:0.9rem;padding:0.65rem 0;">Aktuell keine Termine eingetragen.</li>
        </ul>
      ) : (
        <ul class="termine-list">
          {termine.map((t) => (
            <li>
              <div class="termin-date">
                <span class="td-day">{t.tag}</span>
                <span class="td-mon">{t.monat}</span>
              </div>
              <div class="termin-info">
                <strong>{t.titel}</strong>
                {t.ort && (
                  <span>
                    {t.ort}
                    {t.linkUrl && (
                      <> &middot; <a href={t.linkUrl} target="_blank" rel="noopener">{t.linkText || 'Mehr Info'}</a></>
                    )}
                  </span>
                )}
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

  </main>

  <!-- SIDEBAR -->
  <aside>

    <div class="widget">
      <div class="widget-title">Kontakt Wilhermsdorf</div>
      <div class="widget-body" style="padding:0.75rem 1rem;">
        <ul class="contact-list">
          <li>
            <span class="cl-label">Ansprechperson</span>
            <span class="cl-val">Werner Käferlein</span>
          </li>
          <li>
            <span class="cl-label">Telefon</span>
            <span class="cl-val">09102-1498</span>
          </li>
          <li>
            <span class="cl-label">E-Mail</span>
            <span class="cl-val" style="font-weight:400;font-size:0.84rem;">
              <a id="mail-link-wilhermsdorf" href="#"></a>
            </span>
          </li>
        </ul>
      </div>
    </div>

    <div class="widget">
      <div class="widget-title">Kontakt Langenzenn</div>
      <div class="widget-body" style="padding:0.75rem 1rem;">
        <ul class="contact-list">
          <li>
            <span class="cl-label">Ansprechperson</span>
            <span class="cl-val">Michael Jagla</span>
          </li>
          <li>
            <span class="cl-label">Telefon</span>
            <span class="cl-val">09101-1605</span>
          </li>
          <li>
            <span class="cl-label">E-Mail</span>
            <span class="cl-val" style="font-weight:400;font-size:0.84rem;">
              <a id="mail-link-langenzenn" href="#"></a>
            </span>
          </li>
        </ul>
      </div>
    </div>

    <div class="widget">
      <div class="widget-title">Links</div>
      <div class="widget-body">
        <p><a href="https://www.ligamanager.schachbund-bayern.de/index.htm" target="_blank" rel="noopener">Ligamanager Schachbund Bayern</a></p>
        <p><a href="https://www.schachbund.de/verein/21223.html" target="_blank" rel="noopener">DWZ-Liste Schachfreunde Wilhermsdorf</a></p>
        <p><a href="https://www.schachbund.de/verein/2120A.html" target="_blank" rel="noopener">DWZ-Liste SK 1948 Langenzenn</a></p>
      </div>
    </div>

  </aside>
</div>

<script is:inline>
(function(){
  var u = 'werner.kaeferlein', d = 't-online.de';
  var a = document.getElementById('mail-link-wilhermsdorf');
  if (a) { a.href = 'mailto:' + u + '@' + d; a.textContent = u + '@' + d; }
})();
(function(){
  var u = 'sk1948langenzenn', d = 'freenet.de';
  var a = document.getElementById('mail-link-langenzenn');
  if (a) { a.href = 'mailto:' + u + '@' + d; a.textContent = u + '@' + d; }
})();
</script>

</MainLayout>
